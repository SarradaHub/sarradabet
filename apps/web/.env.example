# Copy to .env: cp apps/web/.env.example apps/web/.env

# Production / preview builds — API base URL (no /api/v1 suffix)
# VITE_API_URL=https://api.your-domain.com

# Local dev (recommended): leave VITE_API_URL unset and use Vite proxy.
# Requests go to same origin (/api/...) and proxy to http://localhost:8000
# Set VITE_API_DIRECT=true only if you need the browser to call :8000 directly.
# VITE_API_DIRECT=true
# VITE_API_URL=http://localhost:8000
