    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^9.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express-rate-limit": "^5.1.3",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.19.1",
    "@types/opossum": "^8.1.9",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "fishery": "^2.2.2",
    "globals": "^16.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@sarradabet/types": "*",
    "@types/express": "^5.0.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.0",
    "consul": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "esm": "^3.2.25",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.2.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "opossum": "^7.0.0",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  }
