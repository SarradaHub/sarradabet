{
  "name": "api",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPatterns=integration",
    "test:integration:setup": "tsx src/__tests__/helpers/setupTestDatabase.cli.ts",
    "db:test:setup": "tsx src/__tests__/helpers/setupTestDatabase.cli.ts",
    "test:unit": "jest --testPathPattern=__tests__ --testPathIgnorePatterns=integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:check": "prisma migrate status",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:simple": "npx tsx prisma/seed-simple.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed:simple",
    "mp:setup-store": "tsx scripts/setupMercadoPagoStore.ts",
    "webhook:configure": "tsx scripts/configureWebhookTunnel.ts",
    "webhook:tunnel": "bash scripts/runNgrok.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
