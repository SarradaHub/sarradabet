NODE_ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:3002,http://localhost:5173

# Database (local Docker Compose uses port 5433)
DATABASE_URL=postgresql://appuser:sarradabet1234@localhost:5433/sarradabet
DIRECT_URL=postgresql://appuser:sarradabet1234@localhost:5433/sarradabet

# Auth
JWT_SECRET=dev-jwt-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Mercado Pago — online Pix (coin purchases)
# Put real tokens in .env.local (gitignored); see docs/features/07-mercadopago-qr-instore.md
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# Local dev: ngrok authtoken — see docs/LOCAL_WEBHOOKS.md
# NGROK_AUTHTOKEN=
MERCADOPAGO_NOTIFICATION_URL=http://localhost:8000/api/v1/webhooks/mercadopago
PIX_EXPIRATION_MINUTES=30
MERCADOPAGO_MOCK_PIX=false

# Mercado Pago — in-person QR setup (step 2: loja e caixa)
# Optional override; otherwise resolved via GET /users/me during setup
MERCADOPAGO_USER_ID=
MERCADOPAGO_STORE_EXTERNAL_ID=SARRADABET001
MERCADOPAGO_STORE_NAME=SarradaBet Loja
MERCADOPAGO_STORE_STREET_NAME=Rua Exemplo
MERCADOPAGO_STORE_STREET_NUMBER=123
MERCADOPAGO_STORE_CITY_NAME=São Paulo
MERCADOPAGO_STORE_STATE_NAME=São Paulo
MERCADOPAGO_STORE_LATITUDE=-23.55052
MERCADOPAGO_STORE_LONGITUDE=-46.633308
MERCADOPAGO_STORE_REFERENCE=
MERCADOPAGO_POS_EXTERNAL_ID=SARRADABET001POS001
MERCADOPAGO_POS_NAME=SarradaBet Caixa
MERCADOPAGO_POS_CATEGORY=

# Mercado Pago — in-person QR runtime IDs (filled by npm run mp:setup-store)
MERCADOPAGO_STORE_ID=
MERCADOPAGO_POS_ID=
MERCADOPAGO_POS_UUID=
